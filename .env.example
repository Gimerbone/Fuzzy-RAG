# PostgreSQL
POSTGRES_USER=fuzzyrag
POSTGRES_PASSWORD=fuzzyrag
POSTGRES_DB=fuzzyrag

# HuggingFace token — required for gated models (MedGemma)
# Accept the licence at https://huggingface.co/google/medgemma-4b-it then generate a token
# at https://huggingface.co/settings/tokens (read access is sufficient)
HF_TOKEN=hf_...

# LLM (local HuggingFace model, loaded with bitsandbytes quantization)
LLM_MODEL=google/medgemma-4b-it
# 4 = NF4 4-bit (~3-4 GB VRAM), 8 = LLM.int8 (~6 GB VRAM)
LOAD_BITS=4

# GPU memory planning (optional). The model fills the GPU first and offloads any
# overflow to CPU RAM automatically, so it loads even on a small GPU.
# Set GPU_MAX_MEMORY to cap how much VRAM the planner uses, e.g. "10GiB".
# Leave blank to let it use the whole GPU.
GPU_MAX_MEMORY=
CPU_MAX_MEMORY=30GiB

# Embedding model (BiomedCLIP via open_clip — 512-dim projected CLIP space)
# Verify dim after first load: model.encode_text(tokens).shape[-1]
EMBEDDING_MODEL=hf-hub:microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224
VECTOR_DIM=512

# Retrieval settings
RRF_K=60
TOP_K=5

# RadQA dataset (requires PhysioNet credentialed access)
# If PHYSIONET_USER and PHYSIONET_PASSWORD are set the files are downloaded automatically.
# Otherwise place radqa_train.json, radqa_dev.json, radqa_test.json in RADQA_DATA_PATH manually.
# Apply for access at https://physionet.org/content/radqa/1.0.0/
RADQA_DATA_PATH=./data/radqa
PHYSIONET_USER=
PHYSIONET_PASSWORD=

# Path where baseline evaluation results are saved
BASELINES_PATH=./baselines
